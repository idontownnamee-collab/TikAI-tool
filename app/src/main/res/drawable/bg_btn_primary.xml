<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape><solid android:color="#BB2E0050"/><corners android:radius="14dp"/></shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="@color/accent_pink" android:endColor="@color/accent_purple"
                android:angle="135"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
</selector>
